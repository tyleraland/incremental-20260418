{
  "name": "incremental-20260418",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "bsnap": "node scripts/bsnap.mjs",
    "import-svg": "node scripts/import-svg.mjs",
    "codemap": "cd tools/codemap && npm install && npm run build && rm -rf ../../public/codemap && cp -R dist ../../public/codemap",
    "coverage": "vitest run --coverage.enabled --coverage.provider=v8 --coverage.all --coverage.reporter=json --coverage.reportsDirectory=coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "ci": "tsc --noEmit && vitest run",
    "e2e": "playwright test",
    "skin-ab": "playwright test skin-compare.spec.ts --project=mobile-chrome",
    "perf-probe": "playwright test dense-probe.spec.ts --project=mobile-chrome --workers=1",
    "e2e:install": "playwright install chromium",
    "gallery-shot": "playwright test gallery.spec.ts --project=mobile-chrome",
    "body-shot": "playwright test body-sheet.spec.ts --project=desktop-chrome"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/utilities": "^3.2.2",
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.19",
    "classcat": "^5.0.4",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.5",
    "vitest": "^4.1.5"
  }
}
