  "scripts": {
    "check:node": "\"${npm_node_execpath:-node}\" scripts/check-node.mjs",
    "predev": "\"${npm_node_execpath:-node}\" scripts/check-node.mjs",
    "dev": "\"${npm_node_execpath:-node}\" ./node_modules/vite/bin/vite.js",
    "prebuild": "\"${npm_node_execpath:-node}\" scripts/check-node.mjs",
    "build": "\"${npm_node_execpath:-node}\" ./node_modules/typescript/bin/tsc && \"${npm_node_execpath:-node}\" ./node_modules/vite/bin/vite.js build",
    "preview": "\"${npm_node_execpath:-node}\" ./node_modules/vite/bin/vite.js preview",
    "pretest": "\"${npm_node_execpath:-node}\" scripts/check-node.mjs",
    "test": "\"${npm_node_execpath:-node}\" ./node_modules/vitest/vitest.mjs run",
    "bsnap": "\"${npm_node_execpath:-node}\" scripts/bsnap.mjs",
    "import-svg": "\"${npm_node_execpath:-node}\" scripts/import-svg.mjs",
    "codemap": "cd tools/codemap && npm install && npm run build && rm -rf ../../public/codemap && cp -R dist ../../public/codemap",
    "coverage": "\"${npm_node_execpath:-node}\" ./node_modules/vitest/vitest.mjs run --coverage.enabled --coverage.provider=v8 --coverage.all --coverage.reporter=json --coverage.reportsDirectory=coverage",
    "test:watch": "\"${npm_node_execpath:-node}\" ./node_modules/vitest/vitest.mjs",
    "test:ui": "\"${npm_node_execpath:-node}\" ./node_modules/vitest/vitest.mjs --ui",
    "preci": "\"${npm_node_execpath:-node}\" scripts/check-node.mjs",
    "ci": "\"${npm_node_execpath:-node}\" ./node_modules/typescript/bin/tsc --noEmit && \"${npm_node_execpath:-node}\" ./node_modules/vitest/vitest.mjs run",
    "e2e": "\"${npm_node_execpath:-node}\" ./node_modules/playwright/cli.js test",
    "skin-ab": "\"${npm_node_execpath:-node}\" ./node_modules/playwright/cli.js test skin-compare.spec.ts --project=mobile-chrome",
    "perf-probe": "\"${npm_node_execpath:-node}\" ./node_modules/playwright/cli.js test dense-probe.spec.ts --project=mobile-chrome --workers=1",
    "horse-rig-perf": "\"${npm_node_execpath:-node}\" ./node_modules/playwright/cli.js test horse-rig-perf.spec.ts --project=mobile-chrome --workers=1",
    "horse-battle-e2e": "\"${npm_node_execpath:-node}\" ./node_modules/playwright/cli.js test horse-battle-preview.spec.ts --project=mobile-chrome --workers=1",
    "e2e:install": "\"${npm_node_execpath:-node}\" ./node_modules/playwright/cli.js install chromium",
    "gallery-shot": "\"${npm_node_execpath:-node}\" ./node_modules/playwright/cli.js test gallery.spec.ts --project=mobile-chrome",
    "body-shot": "\"${npm_node_execpath:-node}\" ./node_modules/playwright/cli.js test body-sheet.spec.ts --project=desktop-chrome",
    "knip": "\"${npm_node_execpath:-node}\" ./node_modules/knip/bin/knip.js"
  },
  "dependencies": {
    "fflate": "^0.8.3",
